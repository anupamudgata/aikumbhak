# Copy to .env.local for local dev, and add the same keys in Vercel → Project → Settings → Environment Variables.
# NEVER commit real values. NEVER expose the service-role or secret keys to the browser.

# --- Razorpay (Dashboard → Settings → API Keys) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxx        # optional, hardens the webhook

# --- Supabase (Project Settings → API) ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxx          # SERVER ONLY — bypasses RLS, never ship to client
SUPABASE_ANON_KEY=xxxxxxxx                  # safe for client auth (magic link)

# --- Pricing ---
PRO_PRICE_PAISE=49900                       # ₹499 (Razorpay amounts are in paise)

# --- AI coach (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...                 # for /api/ai-session (Claude Haiku)

# --- Native IAP (RevenueCat → /api/iap-webhook) ---
REVENUECAT_WEBHOOK_AUTH=choose-a-long-secret # must match the Authorization header set in RevenueCat
# The RevenueCat *public* SDK key goes in index.html (REVENUECAT_API_KEY) — safe to expose.

# --- App ---
APP_URL=https://your-app.vercel.app         # used for magic-link sign-in redirects

# In index.html, also set the public RAZORPAY_KEY_ID (the rzp_... id is safe to expose;
# the SECRET stays server-side only).
